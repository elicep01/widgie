{
  "id": "news-headlines",
  "name": "News Headlines",
  "description": "Live breaking news from BBC, CNN, NPR, Reuters & more — auto-cycles through latest stories.",
  "category": "media",
  "config": {
    "name": "News Headlines",
    "description": "Live news feed from top sources",
    "size": { "width": 240, "height": 120 },
    "theme": "obsidian",
    "cornerRadius": 16,
    "padding": { "top": 12, "bottom": 12, "leading": 14, "trailing": 14 },
    "refreshInterval": 300,
    "content": {
      "type": "news_headlines",
      "feedUrls": [
        "https://feeds.bbci.co.uk/news/rss.xml",
        "https://rss.nytimes.com/services/xml/rss/nyt/HomePage.xml",
        "https://feeds.npr.org/1001/rss.xml",
        "http://rss.cnn.com/rss/edition.rss",
        "https://www.theguardian.com/world/rss"
      ],
      "maxItems": 3,
      "rotateInterval": 8,
      "showSource": true,
      "size": 11,
      "color": "primary"
    },
    "maxSize": { "width": 320, "height": 180 }
  }
}
