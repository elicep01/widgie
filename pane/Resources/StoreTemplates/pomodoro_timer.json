{
  "id": "pomodoro-timer",
  "name": "Pomodoro Timer",
  "description": "Focus ring with work/break cycles and session counter.",
  "category": "productivity",
  "config": {
    "name": "Pomodoro Timer",
    "description": "Pomodoro focus timer",
    "size": {
      "width": 160,
      "height": 150
    },
    "theme": "obsidian",
    "cornerRadius": 16,
    "padding": {
      "top": 10,
      "bottom": 8,
      "leading": 10,
      "trailing": 10
    },
    "content": {
      "type": "pomodoro",
      "workDuration": 1500,
      "breakDuration": 300,
      "longBreakDuration": 900,
      "sessionsBeforeLongBreak": 4,
      "showSessionCount": true,
      "style": "ring",
      "workColor": "negative",
      "breakColor": "positive",
      "showControls": true,
      "alignment": "center"
    },
    "maxSize": {
      "width": 210,
      "height": 190
    }
  }
}
