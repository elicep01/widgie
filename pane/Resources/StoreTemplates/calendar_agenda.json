{
  "id": "calendar-agenda",
  "name": "Today's Agenda",
  "description": "Your upcoming calendar events at a glance.",
  "category": "productivity",
  "config": {
    "name": "Today's Agenda",
    "description": "Next calendar events",
    "size": {
      "width": 210,
      "height": 110
    },
    "theme": "obsidian",
    "cornerRadius": 14,
    "padding": {
      "top": 10,
      "bottom": 10,
      "leading": 12,
      "trailing": 12
    },
    "content": {
      "type": "vstack",
      "alignment": "leading",
      "spacing": 4,
      "children": [
        {
          "type": "text",
          "content": "Agenda",
          "size": 14,
          "weight": "semibold",
          "color": "primary"
        },
        {
          "type": "calendar_next",
          "source": "system_calendar",
          "maxEvents": 3,
          "showTime": true,
          "showCalendarColor": true,
          "timeRange": "today",
          "emptyText": "No events today",
          "font": "sf-pro",
          "size": 14,
          "color": "primary"
        }
      ]
    },
    "maxSize": {
      "width": 280,
      "height": 150
    }
  }
}
