{
  "id": "productivity-daily",
  "name": "Daily Focus",
  "description": "Day progress, goals checklist, and a motivational quote side-by-side.",
  "category": "productivity",
  "config": {
    "name": "Daily Focus",
    "description": "Day progress + goals + quote",
    "size": {
      "width": 260,
      "height": 150
    },
    "theme": "obsidian",
    "cornerRadius": 14,
    "padding": {
      "top": 10,
      "bottom": 10,
      "leading": 12,
      "trailing": 12
    },
    "content": {
      "type": "hstack",
      "alignment": "top",
      "spacing": 8,
      "children": [
        {
          "type": "vstack",
          "alignment": "leading",
          "spacing": 4,
          "children": [
            {
              "type": "text",
              "content": "Today",
              "size": 14,
              "weight": "semibold",
              "color": "primary"
            },
            {
              "type": "day_progress",
              "startHour": 7,
              "endHour": 23,
              "style": "bar",
              "showPercentage": true,
              "showTimeRemaining": false,
              "color": "accent"
            },
            {
              "type": "quote",
              "source": "curated",
              "category": "motivation",
              "refreshInterval": "daily",
              "font": "new-york",
              "size": 14,
              "weight": "regular",
              "color": "muted",
              "authorColor": "muted",
              "showQuotationMarks": true
            }
          ]
        },
        {
          "type": "divider",
          "color": "muted",
          "thickness": 0.5,
          "direction": "vertical"
        },
        {
          "type": "vstack",
          "alignment": "leading",
          "spacing": 3,
          "children": [
            {
              "type": "text",
              "content": "Goals",
              "size": 14,
              "weight": "semibold",
              "color": "secondary"
            },
            {
              "type": "checklist",
              "items": [
                {
                  "id": "1",
                  "text": "Deep work block",
                  "checked": false
                },
                {
                  "id": "2",
                  "text": "Inbox zero",
                  "checked": false
                },
                {
                  "id": "3",
                  "text": "Workout",
                  "checked": false
                }
              ],
              "resetsDaily": true,
              "showProgress": false,
              "interactive": true,
              "checkedColor": "positive",
              "uncheckedColor": "muted",
              "strikethrough": true,
              "font": "sf-pro",
              "size": 14,
              "color": "primary"
            }
          ]
        }
      ]
    },
    "maxSize": {
      "width": 340,
      "height": 200
    }
  }
}
