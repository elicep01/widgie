{
  "id": "system-monitor",
  "name": "System Monitor",
  "description": "CPU, memory, and storage usage at a glance.",
  "category": "system",
  "config": {
    "name": "System Monitor",
    "description": "CPU/Memory/Storage bars",
    "size": {
      "width": 200,
      "height": 90
    },
    "theme": "neon",
    "background": {
      "type": "gradient",
      "colors": ["#0A0A0A", "#0D1117", "#0A0A0A"]
    },
    "cornerRadius": 16,
    "padding": {
      "top": 8,
      "bottom": 8,
      "leading": 10,
      "trailing": 10
    },
    "refreshInterval": 10,
    "content": {
      "type": "vstack",
      "alignment": "leading",
      "spacing": 4,
      "children": [
        {
          "type": "hstack",
          "alignment": "center",
          "spacing": 4,
          "children": [
            {
              "type": "icon",
              "name": "cpu",
              "size": 11,
              "color": "accent"
            },
            {
              "type": "text",
              "content": "System",
              "size": 11,
              "weight": "bold",
              "color": "primary"
            }
          ]
        },
        {
          "type": "system_stats",
          "style": "bars",
          "showCPU": true,
          "showMemory": true,
          "showStorage": true,
          "barColor": "accent",
          "labelColor": "muted",
          "size": 10
        }
      ]
    },
    "maxSize": {
      "width": 260,
      "height": 120
    }
  }
}
