{
  "id": "system-monitor",
  "name": "System Monitor",
  "description": "CPU, memory, and storage usage at a glance.",
  "category": "system",
  "config": {
    "name": "System Monitor",
    "description": "CPU/Memory/Storage bars",
    "size": {
      "width": 200,
      "height": 90
    },
    "theme": "obsidian",
    "cornerRadius": 16,
    "padding": {
      "top": 10,
      "bottom": 10,
      "leading": 12,
      "trailing": 12
    },
    "refreshInterval": 10,
    "content": {
      "type": "vstack",
      "alignment": "leading",
      "spacing": 4,
      "children": [
        {
          "type": "hstack",
          "alignment": "center",
          "spacing": 4,
          "children": [
            {
              "type": "icon",
              "name": "cpu",
              "size": 14,
              "color": "accent"
            },
            {
              "type": "text",
              "content": "System",
              "size": 14,
              "weight": "bold",
              "color": "primary"
            }
          ]
        },
        {
          "type": "system_stats",
          "style": "bars",
          "showCPU": true,
          "showMemory": true,
          "showStorage": true,
          "barColor": "accent",
          "labelColor": "muted",
          "size": 14
        }
      ]
    },
    "maxSize": {
      "width": 260,
      "height": 120
    }
  }
}
