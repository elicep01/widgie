            {
              "id": "1",
              "text": "Morning workout",
              "checked": false
            },
            {
              "id": "2",
              "text": "Review emails",
              "checked": false
            },
            {
              "id": "3",
              "text": "Deep work block",
              "checked": false
            },
            {
              "id": "4",
              "text": "Ship one thing",
              "checked": false
            }
