{
  "id": "crypto-tracker",
  "name": "Crypto Tracker",
  "description": "Live Bitcoin and Ethereum prices with change indicators.",
  "category": "finance",
  "config": {
    "name": "Crypto Tracker",
    "description": "BTC + ETH live tracker",
    "size": {
      "width": 240,
      "height": 110
    },
    "theme": "midnight",
    "background": {
      "type": "gradient",
      "colors": ["#0F0C29", "#302B63", "#24243E"]
    },
    "cornerRadius": 16,
    "padding": {
      "top": 10,
      "bottom": 10,
      "leading": 12,
      "trailing": 12
    },
    "refreshInterval": 60,
    "content": {
      "type": "vstack",
      "spacing": 6,
      "children": [
        {
          "type": "hstack",
          "alignment": "center",
          "spacing": 6,
          "children": [
            {
              "type": "icon",
              "name": "bitcoinsign.circle.fill",
              "size": 14,
              "color": "#F7931A"
            },
            {
              "type": "text",
              "content": "Crypto",
              "size": 12,
              "weight": "bold",
              "color": "primary"
            }
          ]
        },
        {
          "type": "hstack",
          "alignment": "top",
          "spacing": 10,
          "children": [
            {
              "type": "container",
              "background": "gradient:#F7931A,#E8890C",
              "cornerRadius": 10,
              "padding": {
                "top": 8,
                "bottom": 8,
                "leading": 10,
                "trailing": 10
              },
              "child": {
                "type": "crypto",
                "symbol": "BTC",
                "currency": "USD",
                "showChange": true,
                "showChart": false,
                "size": 12,
                "color": "primary"
              }
            },
            {
              "type": "container",
              "background": "gradient:#627EEA,#4A6CC9",
              "cornerRadius": 10,
              "padding": {
                "top": 8,
                "bottom": 8,
                "leading": 10,
                "trailing": 10
              },
              "child": {
                "type": "crypto",
                "symbol": "ETH",
                "currency": "USD",
                "showChange": true,
                "showChart": false,
                "size": 12,
                "color": "primary"
              }
            }
          ]
        }
      ]
    },
    "maxSize": {
      "width": 320,
      "height": 140
    }
  }
}
