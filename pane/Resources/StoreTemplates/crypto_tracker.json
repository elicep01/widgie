{
  "id": "crypto-tracker",
  "name": "Crypto Tracker",
  "description": "Live Bitcoin and Ethereum prices with change indicators.",
  "category": "finance",
  "config": {
    "name": "Crypto Tracker",
    "description": "BTC + ETH live tracker",
    "size": { "width": 220, "height": 100 },
    "theme": "obsidian",
    "cornerRadius": 16,
    "padding": { "top": 10, "bottom": 10, "leading": 12, "trailing": 12 },
    "refreshInterval": 60,
    "content": {
      "type": "vstack",
      "spacing": 8,
      "children": [
        {
          "type": "hstack",
          "alignment": "top",
          "spacing": 10,
          "children": [
            {
              "type": "crypto",
              "symbol": "BTC",
              "currency": "USD",
              "showChange": true,
              "showChart": false,
              "size": 14,
              "color": "primary"
            },
            {
              "type": "crypto",
              "symbol": "ETH",
              "currency": "USD",
              "showChange": true,
              "showChart": false,
              "size": 14,
              "color": "primary"
            }
          ]
        }
      ]
    },
    "maxSize": { "width": 300, "height": 130 }
  }
}
