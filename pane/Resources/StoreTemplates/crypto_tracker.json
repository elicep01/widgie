{
  "id": "crypto-tracker",
  "name": "Crypto Tracker",
  "description": "Live Bitcoin and Ethereum prices with 24h change.",
  "category": "finance",
  "config": {
    "name": "Crypto Tracker",
    "description": "BTC + ETH live tracker",
    "size": {
      "width": 200,
      "height": 120
    },
    "theme": "obsidian",
    "cornerRadius": 18,
    "padding": {
      "top": 12,
      "bottom": 12,
      "leading": 14,
      "trailing": 14
    },
    "refreshInterval": 60,
    "content": {
      "type": "vstack",
      "alignment": "center",
      "spacing": 10,
      "children": [
        {
          "type": "text",
          "content": "Crypto",
          "font": "sf-pro",
          "size": 14,
          "weight": "semibold",
          "color": "muted",
          "alignment": "center"
        },
        {
          "type": "crypto",
          "symbol": "BTC",
          "currency": "USD",
          "showChange": true,
          "showChart": false,
          "size": 16,
          "color": "primary",
          "alignment": "center"
        },
        {
          "type": "divider",
          "color": "muted",
          "direction": "horizontal",
          "thickness": 0.5
        },
        {
          "type": "crypto",
          "symbol": "ETH",
          "currency": "USD",
          "showChange": true,
          "showChart": false,
          "size": 16,
          "color": "primary",
          "alignment": "center"
        }
      ]
    },
    "maxSize": {
      "width": 260,
      "height": 160
    }
  }
}
