{
  "name": "Seattle Weather",
  "size": {
    "width": 175,
    "height": 80
  },
  "theme": "obsidian",
  "background": {
    "type": "blur",
    "material": "hudWindow",
    "tintColor": "#0D1117",
    "tintOpacity": 0.7
  },
  "cornerRadius": 18,
  "padding": {
    "top": 10,
    "bottom": 10,
    "leading": 10,
    "trailing": 10
  },
  "content": {
    "type": "weather",
    "location": "Seattle, WA, USA",
    "showIcon": true,
    "showTemperature": true,
    "showCondition": true,
    "showHighLow": true,
    "showHumidity": false,
    "showWind": false,
    "temperatureUnit": "fahrenheit",
    "style": "compact",
    "color": "primary"
  },
  "dataSources": {
    "weather": {
      "provider": "openweather",
      "location": "Seattle, WA, USA",
      "refreshInterval": 1800
    }
  }
}
