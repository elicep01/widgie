{
  "name": "Pune Weather",
  "size": {
    "width": 220,
    "height": 130
  },
  "theme": "obsidian",
  "background": {
    "type": "blur",
    "material": "hudWindow",
    "tintColor": "#0D1117",
    "tintOpacity": 0.7
  },
  "cornerRadius": 20,
  "padding": {
    "top": 10,
    "bottom": 10,
    "leading": 10,
    "trailing": 10
  },
  "content": {
    "type": "weather",
    "location": "Pune, Maharashtra, India",
    "showIcon": true,
    "showTemperature": true,
    "showCondition": true,
    "showHighLow": true,
    "showHumidity": true,
    "showWind": true,
    "showFeelsLike": true,
    "temperatureUnit": "celsius",
    "style": "detailed",
    "forecastDays": 5,
    "color": "primary"
  },
  "dataSources": {
    "weather": {
      "provider": "openweather",
      "location": "Pune, Maharashtra, India",
      "refreshInterval": 1800
    }
  }
}
