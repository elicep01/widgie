{
  "name": "Clock and Date",
  "size": {
    "width": 170,
    "height": 80
  },
  "theme": "obsidian",
  "background": {
    "type": "blur",
    "material": "hudWindow",
    "tintColor": "#0D1117",
    "tintOpacity": 0.7
  },
  "cornerRadius": 18,
  "padding": {
    "top": 10,
    "bottom": 10,
    "leading": 10,
    "trailing": 10
  },
  "content": {
    "type": "vstack",
    "alignment": "center",
    "spacing": 4,
    "children": [
      {
        "type": "clock",
        "style": "digital",
        "timezone": "local",
        "format": "h:mm a",
        "font": "sf-mono",
        "size": 32,
        "weight": "light",
        "color": "primary"
      },
      {
        "type": "date",
        "format": "EEEE, MMMM d",
        "font": "sf-pro",
        "size": 12,
        "weight": "regular",
        "color": "muted"
      }
    ]
  }
}
