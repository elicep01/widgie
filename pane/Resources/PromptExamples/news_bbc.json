{
  "name": "BBC News",
  "size": {
    "width": 230,
    "height": 110
  },
  "theme": "obsidian",
  "background": {
    "type": "blur",
    "material": "hudWindow",
    "tintColor": "#0D1117",
    "tintOpacity": 0.7
  },
  "cornerRadius": 18,
  "padding": {
    "top": 10,
    "bottom": 10,
    "leading": 10,
    "trailing": 10
  },
  "content": {
    "type": "news_headlines",
    "source": "rss",
    "feedUrl": "https://feeds.bbci.co.uk/news/rss.xml",
    "maxItems": 4,
    "showSource": true,
    "rotateInterval": 0,
    "font": "sf-pro",
    "size": 13,
    "color": "primary"
  },
  "refreshInterval": 1800
}
