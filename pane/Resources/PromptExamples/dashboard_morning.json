{
  "name": "Morning Dashboard",
  "size": {
    "width": 320,
    "height": 145
  },
  "theme": "obsidian",
  "background": {
    "type": "gradient",
    "colors": [
      "#0D1117",
      "#161B22"
    ],
    "direction": "topToBottom"
  },
  "cornerRadius": 18,
  "padding": {
    "top": 10,
    "bottom": 10,
    "leading": 10,
    "trailing": 10
  },
  "content": {
    "type": "hstack",
    "alignment": "top",
    "spacing": 14,
    "children": [
      {
        "type": "vstack",
        "alignment": "leading",
        "spacing": 5,
        "children": [
          {
            "type": "clock",
            "style": "digital",
            "timezone": "local",
            "format": "h:mm a",
            "font": "sf-mono",
            "size": 26,
            "weight": "light",
            "color": "primary"
          },
          {
            "type": "date",
            "format": "EEE, MMM d",
            "font": "sf-pro",
            "size": 12,
            "weight": "regular",
            "color": "muted"
          },
          {
            "type": "weather",
            "location": "Madison, WI, USA",
            "style": "compact",
            "showIcon": true,
            "showTemperature": true,
            "showCondition": true,
            "showHighLow": true,
            "temperatureUnit": "fahrenheit",
            "color": "primary"
          },
          {
            "type": "day_progress",
            "startHour": 7,
            "endHour": 23,
            "style": "bar",
            "showPercentage": true,
            "showTimeRemaining": false,
            "color": "accent",
            "label": "Day"
          }
        ]
      },
      {
        "type": "divider",
        "color": "muted",
        "thickness": 0.5,
        "direction": "vertical"
      },
      {
        "type": "vstack",
        "alignment": "leading",
        "spacing": 5,
        "children": [
          {
            "type": "calendar_next",
            "source": "system_calendar",
            "maxEvents": 2,
            "showTime": true,
            "showCalendarColor": true,
            "timeRange": "today",
            "emptyText": "No events",
            "font": "sf-pro",
            "size": 12,
            "color": "primary"
          },
          {
            "type": "divider",
            "color": "muted",
            "thickness": 0.5,
            "direction": "horizontal"
          },
          {
            "type": "checklist",
            "title": "Today",
            "items": [
              {
                "id": "1",
                "text": "Morning workout",
                "checked": false
              },
              {
                "id": "2",
                "text": "Review emails",
                "checked": false
              },
              {
                "id": "3",
                "text": "Deep work block",
                "checked": false
              }
            ],
            "resetsDaily": true,
            "showProgress": false,
            "interactive": true,
            "checkedColor": "positive",
            "uncheckedColor": "muted",
            "strikethrough": true,
            "font": "sf-pro",
            "size": 12,
            "color": "primary"
          }
        ]
      }
    ]
  }
}
