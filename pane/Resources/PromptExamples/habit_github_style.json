{
  "name": "Habit Tracker",
  "size": {
    "width": 230,
    "height": 130
  },
  "theme": "obsidian",
  "background": {
    "type": "blur",
    "material": "hudWindow",
    "tintColor": "#0D1117",
    "tintOpacity": 0.7
  },
  "cornerRadius": 20,
  "padding": {
    "top": 10,
    "bottom": 10,
    "leading": 10,
    "trailing": 10
  },
  "content": {
    "type": "habit_tracker",
    "habits": [
      {
        "id": "workout",
        "name": "Workout",
        "icon": "figure.run",
        "target": 1,
        "unit": "session"
      },
      {
        "id": "reading",
        "name": "Reading",
        "icon": "book.fill",
        "target": 30,
        "unit": "minutes"
      },
      {
        "id": "water",
        "name": "Water",
        "icon": "drop.fill",
        "target": 8,
        "unit": "glasses"
      }
    ],
    "style": "grid",
    "interactive": true,
    "showStreak": true,
    "color": "positive"
  }
}
