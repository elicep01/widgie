{
  "name": "Today Events",
  "size": {
    "width": 220,
    "height": 140
  },
  "theme": "obsidian",
  "background": {
    "type": "blur",
    "material": "hudWindow",
    "tintColor": "#0D1117",
    "tintOpacity": 0.7
  },
  "cornerRadius": 18,
  "padding": {
    "top": 10,
    "bottom": 10,
    "leading": 10,
    "trailing": 10
  },
  "content": {
    "type": "calendar_next",
    "source": "system_calendar",
    "maxEvents": 5,
    "showTime": true,
    "showCalendarColor": true,
    "timeRange": "today",
    "emptyText": "Nothing scheduled today",
    "font": "sf-pro",
    "size": 13,
    "color": "primary"
  }
}
