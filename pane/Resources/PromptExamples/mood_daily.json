{
  "name": "Mood",
  "size": {
    "width": 170,
    "height": 90
  },
  "theme": "obsidian",
  "background": {
    "type": "blur",
    "material": "hudWindow",
    "tintColor": "#0D1117",
    "tintOpacity": 0.7
  },
  "cornerRadius": 18,
  "padding": {
    "top": 10,
    "bottom": 10,
    "leading": 10,
    "trailing": 10
  },
  "content": {
    "type": "vstack",
    "alignment": "center",
    "spacing": 10,
    "children": [
      {
        "type": "text",
        "content": "How are you feeling?",
        "font": "sf-pro",
        "size": 13,
        "weight": "medium",
        "color": "secondary"
      },
      {
        "type": "shortcut_launcher",
        "shortcuts": [
          {
            "name": "Great",
            "icon": "face.smiling.fill",
            "action": "mood:great"
          },
          {
            "name": "Good",
            "icon": "face.smiling",
            "action": "mood:good"
          },
          {
            "name": "Okay",
            "icon": "face.dashed",
            "action": "mood:okay"
          },
          {
            "name": "Bad",
            "icon": "face.dashed.fill",
            "action": "mood:bad"
          },
          {
            "name": "Awful",
            "icon": "cloud.rain.fill",
            "action": "mood:awful"
          }
        ],
        "style": "row",
        "iconSize": 28,
        "color": "primary"
      }
    ]
  }
}
