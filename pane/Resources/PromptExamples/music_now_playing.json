{
  "name": "Now Playing",
  "description": "Live track info and playback controls — auto-detects Spotify or Apple Music",
  "size": {
    "width": 280,
    "height": 130
  },
  "theme": "obsidian",
  "background": {
    "type": "blur",
    "material": "hudWindow",
    "tintColor": "#0D1117",
    "tintOpacity": 0.7
  },
  "cornerRadius": 18,
  "padding": {
    "top": 10,
    "bottom": 10,
    "leading": 12,
    "trailing": 12
  },
  "refreshInterval": 2,
  "content": {
    "type": "music_now_playing",
    "showArtist": true,
    "showProgress": true,
    "showControls": true,
    "color": "primary"
  }
}
