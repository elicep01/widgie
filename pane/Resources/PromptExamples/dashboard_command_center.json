{
  "name": "Command Center",
  "size": {
    "width": 320,
    "height": 160
  },
  "theme": "obsidian",
  "background": {
    "type": "gradient",
    "colors": [
      "#0D1117",
      "#161B22"
    ],
    "direction": "topToBottom"
  },
  "cornerRadius": 18,
  "padding": {
    "top": 10,
    "bottom": 10,
    "leading": 10,
    "trailing": 10
  },
  "content": {
    "type": "hstack",
    "alignment": "top",
    "spacing": 14,
    "children": [
      {
        "type": "vstack",
        "alignment": "center",
        "spacing": 5,
        "children": [
          {
            "type": "pomodoro",
            "workDuration": 1500,
            "breakDuration": 300,
            "longBreakDuration": 900,
            "sessionsBeforeLongBreak": 4,
            "showSessionCount": true,
            "style": "ring",
            "workColor": "negative",
            "breakColor": "positive",
            "showControls": true
          },
          {
            "type": "clock",
            "style": "digital",
            "timezone": "local",
            "format": "h:mm a",
            "font": "sf-mono",
            "size": 18,
            "weight": "light",
            "color": "muted"
          }
        ]
      },
      {
        "type": "divider",
        "color": "muted",
        "thickness": 0.5,
        "direction": "vertical"
      },
      {
        "type": "vstack",
        "alignment": "leading",
        "spacing": 5,
        "children": [
          {
            "type": "day_progress",
            "startHour": 8,
            "endHour": 22,
            "style": "bar",
            "showPercentage": true,
            "showTimeRemaining": false,
            "color": "accent",
            "label": "Day"
          },
          {
            "type": "checklist",
            "title": "Focus Tasks",
            "items": [
              {
                "id": "1",
                "text": "Deep work block",
                "checked": false
              },
              {
                "id": "2",
                "text": "Review and respond",
                "checked": false
              },
              {
                "id": "3",
                "text": "Ship one thing",
                "checked": false
              }
            ],
            "resetsDaily": true,
            "showProgress": true,
            "interactive": true,
            "checkedColor": "positive",
            "uncheckedColor": "muted",
            "strikethrough": true,
            "font": "sf-pro",
            "size": 12,
            "color": "primary"
          },
          {
            "type": "quote",
            "source": "curated",
            "category": "motivation",
            "refreshInterval": "daily",
            "font": "new-york",
            "size": 11,
            "weight": "regular",
            "color": "muted",
            "authorColor": "muted",
            "showQuotationMarks": false
          }
        ]
      }
    ]
  }
}
